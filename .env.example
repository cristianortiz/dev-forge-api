# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SERVER_HOST=0.0.0.0
SERVER_PORT=9000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dev_forge
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_INTERVAL=1m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Zitadel (fill in after running Zitadel console setup) ────────────────────
ZITADEL_ISSUER=http://localhost:8080
ZITADEL_CLIENT_ID=

# ── OTEL ──────────────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=dev-forge
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
